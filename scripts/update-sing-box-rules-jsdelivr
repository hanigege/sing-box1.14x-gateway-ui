#!/usr/bin/env bash
set -euo pipefail

BASE_DIR="/etc/sing-box/rules"
CONFIG="/etc/sing-box/config.json"
SING_BOX="/usr/local/bin/sing-box"
SERVICE="sing-box.service"
RESTART_SERVICE="${RULE_UPDATE_RESTART:-1}"
LOCK_FILE="/run/update-sing-box-rules-jsdelivr.lock"
exec 9>"$LOCK_FILE"
if ! flock -n 9; then
  echo "another rule update is already running; exiting"
  exit 0
fi

TMP_DIR="$(mktemp -d)"
trap 'rm -rf "$TMP_DIR"' EXIT

MIRRORS=(
  "https://scg.jgaga.tk/https://raw.githubusercontent.com"
  "https://gh-proxy.com/https://raw.githubusercontent.com"
  "https://gh.llkk.cc/https://raw.githubusercontent.com"
  "https://cdn.jsdelivr.net/gh"
  "https://fastly.jsdelivr.net/gh"
)

GEOSITE=(
  category-ai-chat-!cn
  youtube google telegram github cloudflare netflix facebook instagram tiktok
  speedtest jetbrains spotify disney hbo amazon adobe steam
  category-pt@!cn category-cryptocurrency geolocation-!cn
  cn icloud@cn apple@cn geolocation-cn
)

GEOIP_REQUIRED=(cn)
GEOIP_OPTIONAL=(telegram netflix facebook)
UPDATED_FILES=()
BACKUP_DIR="$TMP_DIR/backup"
NEW_DIR="$TMP_DIR/new"
mkdir -p "$BACKUP_DIR" "$NEW_DIR"

local_addresses() {
  ip -o addr show 2>/dev/null | awk '{print $4}' | cut -d/ -f1
}

resolver_has_external_nameserver() {
  local ns local_ip
  while read -r ns; do
    [ -n "$ns" ] || continue
    case "$ns" in
      127.*|::1|0.0.0.0|::) continue ;;
    esac
    while read -r local_ip; do
      [ "$ns" = "$local_ip" ] && continue 2
    done < <(local_addresses)
    return 0
  done < <(awk '/^nameserver[[:space:]]+/ {print $2}' /etc/resolv.conf 2>/dev/null)
  return 1
}

ensure_host_resolver() {
  if resolver_has_external_nameserver; then
    return
  fi
  echo "host resolver points to localhost/gateway or is empty; using public DNS for rule update"
  rm -f /etc/resolv.conf
  {
    echo "nameserver 223.5.5.5"
    echo "nameserver 1.1.1.1"
    echo "options timeout:2 attempts:2"
  } > /etc/resolv.conf
}

rule_url() {
  local mirror="$1" repo="$2" branch="$3" subdir="$4" name="$5"
  if [[ "$mirror" == *raw.githubusercontent.com ]]; then
    echo "$mirror/${repo}/${branch}/${subdir}-${name}.srs"
  else
    echo "$mirror/${repo}@${branch}/${subdir}-${name}.srs"
  fi
}

SELECTED_MIRRORS=()
select_mirrors() {
  local mirror url probe="$TMP_DIR/probe.srs"
  for mirror in "${MIRRORS[@]}"; do
    url="$(rule_url "$mirror" "SagerNet/sing-geosite" "rule-set" "geosite" "cn")"
    if curl -4 -fsSL --connect-timeout 2 --max-time 5 "$url" -o "$probe" 2>"$TMP_DIR/probe.log" \
      && [ -s "$probe" ] && [ "$(wc -c < "$probe")" -gt 16 ]; then
      SELECTED_MIRRORS+=("$mirror")
      echo "rule mirror available: $mirror"
    else
      echo "rule mirror skipped: $mirror" >&2
    fi
    rm -f "$probe"
  done
  if [ "${#SELECTED_MIRRORS[@]}" -eq 0 ]; then
    echo "WARN: no rule mirror passed quick probe; using configured mirrors with short timeouts" >&2
    SELECTED_MIRRORS=("${MIRRORS[@]}")
  fi
}

fetch_one() {
  local repo="$1" branch="$2" subdir="$3" name="$4" required="${5:-1}"
  local tmp="$NEW_DIR/${subdir}-${name}.srs"
  local current="$BASE_DIR/$subdir/${name}.srs"
  local mirror url
  mkdir -p "$NEW_DIR" "$BASE_DIR/$subdir"
  if [ "$required" = "0" ] && [ ! -s "$current" ]; then
    echo "optional ${subdir}/${name}.srs unavailable; skipped safely"
    return 0
  fi
  for mirror in "${SELECTED_MIRRORS[@]}"; do
    url="$(rule_url "$mirror" "$repo" "$branch" "$subdir" "$name")"
    curl_flags=(-4 -fsSL --connect-timeout 2 --max-time 6)
    if [ "$required" = "0" ]; then
      curl_flags=(-4 -fsSL --silent --show-error --connect-timeout 2 --max-time 5)
    fi
    if curl "${curl_flags[@]}" "$url" -o "$tmp" 2>"$TMP_DIR/curl-${subdir}-${name}.log"; then
      if [ -s "$tmp" ] && [ "$(wc -c < "$tmp")" -gt 16 ]; then
        echo "downloaded ${subdir}/${name}.srs via ${mirror}"
        UPDATED_FILES+=("$subdir/$name.srs:$tmp")
        return 0
      fi
    fi
  done
  if [ -s "$current" ]; then
    echo "WARN: update failed for ${subdir}/${name}.srs; keeping existing file" >&2
    return 0
  fi
  if [ "$required" = "0" ]; then
    echo "optional ${subdir}/${name}.srs unavailable; skipped safely"
    return 0
  fi
  echo "ERROR: update failed for ${subdir}/${name}.srs and no existing file" >&2
  return 1
}

restore_backups() {
  local rel dst bak
  for rel in "${RESTORE_FILES[@]:-}"; do
    dst="$BASE_DIR/$rel"
    bak="$BACKUP_DIR/$rel"
    if [ -f "$bak" ]; then
      install -m 0644 "$bak" "$dst"
    else
      rm -f "$dst"
    fi
  done
}

fail=0
ensure_host_resolver
select_mirrors
for name in "${GEOSITE[@]}"; do
  fetch_one "SagerNet/sing-geosite" "rule-set" "geosite" "$name" 1 || fail=1
done
for name in "${GEOIP_REQUIRED[@]}"; do
  fetch_one "SagerNet/sing-geoip" "rule-set" "geoip" "$name" 1 || fail=1
done
for name in "${GEOIP_OPTIONAL[@]}"; do
  fetch_one "SagerNet/sing-geoip" "rule-set" "geoip" "$name" 0 || true
done

if [ "$fail" -ne 0 ]; then
  exit "$fail"
fi

RESTORE_FILES=()
for entry in "${UPDATED_FILES[@]}"; do
  rel="${entry%%:*}"
  src="${entry#*:}"
  dst="$BASE_DIR/$rel"
  mkdir -p "$(dirname "$BACKUP_DIR/$rel")" "$(dirname "$dst")"
  if [ -f "$dst" ]; then
    cp -a "$dst" "$BACKUP_DIR/$rel"
  fi
  install -m 0644 "$src" "$dst"
  RESTORE_FILES+=("$rel")
  echo "installed $rel"
done

if ! "$SING_BOX" check -c "$CONFIG"; then
  echo "ERROR: sing-box config check failed after rule update; rolling back rule files" >&2
  restore_backups
  "$SING_BOX" check -c "$CONFIG" || true
  exit 1
fi

if [ "$RESTART_SERVICE" = "0" ]; then
  echo "sing-box rule sets updated and config checked. Service restart skipped."
  exit 0
fi

if ! systemctl restart "$SERVICE"; then
  echo "ERROR: sing-box restart failed after rule update; rolling back rule files" >&2
  restore_backups
  "$SING_BOX" check -c "$CONFIG" || true
  systemctl restart "$SERVICE" || true
  systemctl is-active --quiet "$SERVICE" || exit 1
  exit 1
fi

systemctl is-active --quiet "$SERVICE"
echo "sing-box rule sets updated and service restarted safely."
